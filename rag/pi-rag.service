[Unit]
Description=PI Foundry RAG Service — búsqueda semántica de docs
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/pi-foundry/rag
Environment=RAG_PORT=7402
Environment=RAG_EMBED_PROVIDER=local
Environment=RAG_LANCEDB_PATH=/root/pi-foundry/rag/data/lancedb
ExecStart=/root/.nvm/versions/node/v24.14.1/bin/node server.mjs
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pi-rag

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/root/pi-foundry
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LimitNOFILE=128

[Install]
WantedBy=multi-user.target
